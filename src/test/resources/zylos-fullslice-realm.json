{
  "realm": "zylos-fullslice",
  "enabled": true,
  "sslRequired": "none",
  "accessTokenLifespan": 300,
  "clientScopes": [
    {
      "name": "zylos-actor",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false"
      },
      "protocolMappers": [
        {
          "name": "zylos-act-claim",
          "protocol": "openid-connect",
          "protocolMapper": "zylos-act-claim-mapper",
          "consentRequired": false,
          "config": {
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "false"
          }
        }
      ]
    },
    {
      "name": "hello-aud",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false"
      },
      "protocolMappers": [
        {
          "name": "hello-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "zylos-internal-hello",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "zylos-gateway",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "dev-secret-gateway",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "attributes": {
        "standard.token.exchange.enabled": "true",
        "access.token.signed.response.alg": "RS256"
      },
      "defaultClientScopes": [
        "acr",
        "roles",
        "zylos-actor"
      ],
      "optionalClientScopes": [
        "hello-aud"
      ]
    },
    {
      "clientId": "zylos-internal-hello",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "dev-secret-hello",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "attributes": {
        "standard.token.exchange.enabled": "true",
        "access.token.signed.response.alg": "RS256"
      },
      "protocolMappers": [
        {
          "name": "hello-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "zylos-internal-hello",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ],
      "defaultClientScopes": [
        "acr",
        "roles"
      ]
    }
  ]
}
